{
  "name": "tdl-dev",
  "version": "0.0.0",
  "private": true,
  "description": "A JavaScript wrapper for TDLib",
  "scripts": {
    "clean": "rimraf --glob packages/*/dist/ && npm run clean -w tdl",
    "clean-modules": "rm -rf node_modules/ && rm -rf packages/node_modules/",
    "clean-all": "npm run clean && npm run clean-modules",
    "build": "npm run build ---workspaces",
    "check": "tsc && flow check && eslint . --max-warnings 0",
    "test:unit": "npm run check && vitest run --exclude \"tests/integration|tests/authenticated\"",
    "test:integration": "vitest run tests/integration",
    "test:authenticated": "vitest run tests/authenticated",
    "test": "npm run test:unit && npm run test:integration",
    "test:everything": "npm run check && vitest run",
    "prepare": "npm run build",
    "prepack": "npm test"
  },
  "workspaces": [
    "packages/tdl",
    "packages/prebuilt-tdlib",
    "packages/tdl-install-types"
  ],
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/debug": "^4.1.12",
    "@types/node": "^24.2.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.3",
    "flow-bin": "^0.303.0",
    "node-addon-api": "^7.1.1",
    "node-gyp": "^11.3.0",
    "prebuildify": "^6.0.1",
    "prebuilt-tdlib": "^0.1008061.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.39.0",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "eilvelia <hi@eilvelia.cat>",
  "license": "MIT",
  "directories": {
    "example": "examples"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eilvelia/tdl.git"
  },
  "bugs": {
    "url": "https://github.com/eilvelia/tdl/issues"
  },
  "homepage": "https://github.com/eilvelia/tdl#readme"
}
